# WARD Hook Configuration
# Copy to ~/.claude/hooks/ward.env and fill in values.
# This file should NOT be committed to the repo.
#
# Both values are required for Telegram alerting.
# Hooks still function (log-only) without these set.

# Telegram bot token — from @BotFather
TELEGRAM_TOKEN=

# Chat ID to receive WARD block alerts
# Use your personal chat ID or a dedicated #ward-alerts group
TELEGRAM_CHAT_ID=
